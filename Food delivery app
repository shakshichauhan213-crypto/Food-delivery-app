<!DOCTYPE html>
<html>
<head>
  <title>Food Delivery App</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header>
    <h1>🍔 Student Food Hub</h1>
  </header>

  <div class="menu">

    <div class="item">
      <h2>Burger</h2>
      <p>₹50</p>
      <button onclick="addToCart('Burger',50)">Add</button>
    </div>

    <div class="item">
      <h2>Pizza</h2>
      <p>₹120</p>
      <button onclick="addToCart('Pizza',120)">Add</button>
    </div>

    <div class="item">
      <h2>Sandwich</h2>
      <p>₹40</p>
      <button onclick="addToCart('Sandwich',40)">Add</button>
    </div>

  </div>

  <div class="cart">
    <h2>🛒 Cart</h2>
    <ul id="cart"></ul>
    <h3 id="total">Total: ₹0</h3>
    <button onclick="placeOrder()">Place Order</button>
  </div>

  <script src="script.js"></script>
</body>
</html>
body {
  font-family: Arial;
  margin: 0;
  background: #f4f4f4;
  text-align: center;
}

header {
  background: orange;
  color: white;
  padding: 15px;
}

.menu {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 20px;
}

.item {
  background: white;
  padding: 15px;
  border-radius: 10px;
  width: 150px;
}

button {
  background: green;
  color: white;
  border: none;
  padding: 8px;
  cursor: pointer;
}

.cart {
  background: white;
  margin: 20px auto;
  padding: 15px;
  width: 300px;
  border-radius: 10px;
}
let cart = [];
let total = 0;

function addToCart(item, price) {
  cart.push(item);
  total += price;
  displayCart();
}

function displayCart() {
  let cartList = document.getElementById("cart"); // ✅ FIXED ID
  cartList.innerHTML = "";

  cart.forEach(function(item) {
    let li = document.createElement("li");
    li.textContent = item;
    cartList.appendChild(li);
  });

  document.getElementById("total").textContent = "Total: ₹" + total;
}

function placeOrder() {
  if (cart.length === 0) {
    alert("Cart is empty!");
  } else {
    alert("✅ Order placed successfully!");
    cart = [];
    total = 0;
    displayCart();
  }
}
